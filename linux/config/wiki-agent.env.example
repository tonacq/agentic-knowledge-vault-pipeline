# Copy to /etc/wiki-agent/wiki-agent.env and replace all values.
WIKI_AGENT_ROOT=/home/YOUR_LINUX_USER/wiki-agent
WIKI_AGENT_VAULT=/home/YOUR_LINUX_USER/wiki-agent/working/my-channel
WIKI_AGENT_REMOTE=gdrive:Wikis/MyChannelWiki
WIKI_AGENT_BACKUP_REMOTE=gdrive:Wikis_Backups/wiki-agent
# Optional: set only where needed.
WIKI_AGENT_PATH=/home/YOUR_LINUX_USER/.local/bin:/usr/local/bin:/usr/bin:/bin
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
